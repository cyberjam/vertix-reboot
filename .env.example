# --- apps/web (Vercel) ---
# WebSocket URL of the deployed game server. colyseus.js derives the https
# matchmaking endpoint from this automatically.
#   local:      ws://localhost:2567
#   production: wss://vertix-game-server.onrender.com
NEXT_PUBLIC_GAME_SERVER_URL=ws://localhost:2567

# --- apps/game-server (Render) ---
# PORT is injected by Render; locally it defaults to 2567.
# PORT=2567
# Allowed CORS origin for /health (matchmaking CORS is handled by Colyseus).
# CORS_ORIGIN=*

# Optional gameplay/tuning overrides (see ARCHITECTURE.md §2):
# MAP_ID, FFA_TARGET_SCORE, FFA_DURATION_MS, FFA_END_SCREEN_MS, HP_RESPAWN_MS
