{
  "name": "vertix-reboot",
  "version": "0.0.0",
  "private": true,
  "description": "Vertix.io reboot — web top-down arena shooter (Next.js + Phaser 3 + Colyseus)",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "dev:web": "pnpm --filter @vertix/web dev",
    "dev:server": "pnpm --filter @vertix/game-server dev"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "msgpackr-extract", "sharp"]
  }
}
